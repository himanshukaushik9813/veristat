    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
