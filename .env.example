# ---------- database ----------
# Real Postgres (recommended for running worker+web+api together):
DATABASE_URL=postgres://localhost:5432/veristat
DATABASE_POOL_MAX=10
# Without DATABASE_URL, an embedded PGlite database is used at PGLITE_DIR
# (single process at a time; `pnpm --filter @veristat/db serve` exposes it on :5433).
#PGLITE_DIR=.pgdata

# ---------- wallets ----------
# HD mnemonic for the probe wallet pool. Index 0 = treasury (funds gas + deploys),
# indices 1+ = rotating probe wallets. NEVER commit a funded mnemonic.
PROBE_MNEMONIC="test test test test test test test test test test test junk"
WALLET_POOL_SIZE=3
MAX_PROBES_PER_WALLET=25
#SKIP_WALLET_FUNDING=true    # skip gas top-ups (free-mode dev)

# ---------- budget governor ----------
PER_SERVICE_DAILY_USD=0.05
GLOBAL_DAILY_USD=2
MAX_PER_PROBE_USD=0.01

# ---------- chains ----------
#XLAYER_RPC_URL=https://rpc.xlayer.tech
#XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
#BASE_RPC_URL=https://mainnet.base.org

# ---------- contracts (filled after `forge script Deploy` on XLayer testnet) ----------
#EVIDENCE_ANCHOR_ADDRESS=0x...
#IDENTITY_REGISTRY_ADDRESS=0x...
#VALIDATION_REGISTRY_ADDRESS=0x...
#XLAYER_TESTNET_USDT=0x...        # MockUSDT deployed by the same script

# ---------- worker ----------
PROBE_INTERVAL_MS=120000
CRAWL_INTERVAL_MS=900000
ANCHOR_INTERVAL_MS=600000
ATTEST_INTERVAL_MS=600000
ANCHOR_CHAIN=xlayerTestnet
ATTEST_CHAIN=xlayerTestnet
PUBLIC_BASE_URL=http://localhost:3000
VERISTAT_AGENT_DOMAIN=veristat.demo

# ---------- mock ASPs (demo) ----------
MOCK_ASP_PORT=4010
MOCK_ASP_CHAIN=xlayerTestnet
MOCK_ASP_PAYTO=0x000000000000000000000000000000000000dEaD
#MOCK_ASP_FREE=true          # serve without x402 payments (pre-deploy dev)

# ---------- score API ----------
SCORE_API_PORT=4020
SCORE_API_CHAIN=xlayerTestnet
SCORE_API_PAYTO=0x000000000000000000000000000000000000dEaD
DEMO_MODE=true               # bypass paywall for judges; set false for real x402
