{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data/**",
              "components/indicators/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|iconRight|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, iconRight, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CoiBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|key|ref|className|style|children)$/]",
        "message": "<CoiBadge> doesn't accept that prop. Declared props: children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DimensionMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|value|color|style|key|ref|className|style|children)$/]",
        "message": "<DimensionMeter> doesn't accept that prop. Declared props: name, value, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EvidenceRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:summary|children|open|style|key|ref|className|style|children)$/]",
        "message": "<EvidenceRow> doesn't accept that prop. Declared props: summary, children, open, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradeChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:grade|size|style|key|ref|className|style|children)$/]",
        "message": "<GradeChip> doesn't accept that prop. Declared props: grade, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GradeChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<GradeChip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IncidentCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|summary|time|children|style|key|ref|className|style|children)$/]",
        "message": "<IncidentCard> doesn't accept that prop. Declared props: kind, summary, time, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IncidentCard'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:WRONG_ANSWER|STALE_DATA|OVERCHARGE|HONEYPOT_FAILURE|GAMING_SUSPECTED|DISPUTE)$/]",
        "message": "<IncidentCard> kind must be one of 'WRONG_ANSWER' | 'STALE_DATA' | 'OVERCHARGE' | 'HONEYPOT_FAILURE' | 'GAMING_SUSPECTED' | 'DISPUTE'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|sub|children|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, sub, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|style|key|ref|className|style|children)$/]",
        "message": "<LiveChip> doesn't accept that prop. Declared props: label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScoreBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:score|label|style|key|ref|className|style|children)$/]",
        "message": "<ScoreBadge> doesn't accept that prop. Declared props: score, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|width|height|color|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: values, width, height, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|caption|delta|color|chart|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: icon, label, value, caption, delta, color, chart, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusChip> doesn't accept that prop. Declared props: status, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusChip'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:correct|incorrect|stale|overcharge|failed|unverified|confirmed)$/]",
        "message": "<StatusChip> status must be one of 'correct' | 'incorrect' | 'stale' | 'overcharge' | 'failed' | 'unverified' | 'confirmed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TierBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tier|style|key|ref|className|style|children)$/]",
        "message": "<TierBadge> doesn't accept that prop. Declared props: tier, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendArea'] > JSXAttribute > JSXIdentifier[name!=/^(?:values|id|width|height|color|key|ref|className|style|children)$/]",
        "message": "<TrendArea> doesn't accept that prop. Declared props: values, id, width, height, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='TxLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:hash|href|lead|tail|arrow|style|key|ref|className|style|children)$/]",
        "message": "<TxLink> doesn't accept that prop. Declared props: hash, href, lead, tail, arrow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:verdict|dimension|abbrev|style|key|ref|className|style|children)$/]",
        "message": "<VerdictChip> doesn't accept that prop. Declared props: verdict, dimension, abbrev, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='VerdictChip'] > JSXAttribute[name.name='verdict'] > Literal[value!=/^(?:pass|fail|inconclusive|unverifiable)$/]",
        "message": "<VerdictChip> verdict must be one of 'pass' | 'fail' | 'inconclusive' | 'unverifiable'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
